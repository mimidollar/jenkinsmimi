<!DOCTYPE html>
<html>
<head>
    <title>Mimi Auto Company</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            background-color: #f4f4f4;
        }
        header {
            background-color: #111;
            color: white;
            padding: 15px;
            text-align: center;
        }
        nav {
            background-color: #333;
            padding: 10px;
            text-align: center;
        }
        nav a {
            color: white;
            margin: 10px;
            text-decoration: none;
            font-weight: bold;
        }
        .hero {
            background: url('https://images.unsplash.com/photo-1503376780353-7e6692767b70') no-repeat center/cover;
            color: white;
            padding: 100px 20px;
            text-align: center;
        }
        .section {
            padding: 40px;
            text-align: center;
        }
        .cars {
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        .car {
            background: white;
            padding: 20px;
            border-radius: 10px;
            width: 200px;
        }
        footer {
            background-color: #111;
            color: white;
            text-align: center;
            padding: 15px;
        }
    </style>
</head>
<body>

<header>
    <h1>Mimi Auto Company</h1>
    <p>Your trusted partner for quality vehicles</p>
</header>

<nav>
    <a href="#">Home</a>
    <a href="#">Inventory</a>
    <a href="#">Services</a>
    <a href="#">Contact</a>
</nav>

<div class="hero">
    <h2>Drive Your Dream Car Today</h2>
    <p>Affordable. Reliable. Stylish.</p>
</div>

<div class="section">
    <h2>Our Featured Cars</h2>
    <div class="cars">
        <div class="car">
            <h3>Luxury Sedan</h3>
            <p>Comfort and performance combined</p>
        </div>
        <div class="car">
            <h3>Sport Coupe</h3>
            <p>Speed and style for thrill seekers</p>
        </div>
        <div class="car">
            <h3>Family SUV</h3>
            <p>Space and safety for your family</p>
        </div>
    </div>
</div>

<div class="section">
    <h2>Why Choose Us?</h2>
    <p>✔ Quality inspected vehicles</p>
    <p>✔ Affordable pricing</p>
    <p>✔ Excellent customer service</p>
</div>

<footer>
    <p>© 2026 Mimi Auto Company | All Rights Reserved</p>
</footer>

</body>
</html>
